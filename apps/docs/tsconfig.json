{
  "extends": "@kairo-ui/tsconfig/react-library.json",
  "compilerOptions": {
    "allowJs": true,
    "incremental": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "collections/*": ["./.source/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
